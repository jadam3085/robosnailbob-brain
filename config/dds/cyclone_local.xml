<?xml version="1.0" encoding="UTF-8"?>
<!--
  CycloneDDS tuning for RoboSnailBob.

  Key goals:
    - Disable multicast (WiFi switches often drop multicast → STALL on remote viewers)
    - Increase UDP socket receive buffers so camera image bursts don't overflow
    - Tighten heartbeat so stale publisher/subscriber pairs are detected faster
    - Limit discovery to localhost (all nodes run on-robot; remote viewers connect
      via DDS bridge or SSH tunnel, not raw multicast)

  To activate, set the environment variable before launching:
      export CYCLONEDDS_URI=file:///path/to/cyclone_local.xml
  Or use the brain.launch.py which sets this automatically.
-->
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">

  <Domain id="any">

    <General>
      <!--
        Disable multicast: avoids dropped frames when WiFi AP filters multicast,
        and prevents unnecessary broadcast traffic on the robot's local network.
      -->
      <AllowMulticast>false</AllowMulticast>
      <!-- Camera color images can be ~2 MB each; allow large UDP datagrams -->
      <MaxMessageSize>65500B</MaxMessageSize>
      <!-- Fragment threshold: split payloads above this to avoid IP fragmentation loss -->
      <FragmentSize>1400B</FragmentSize>
    </General>

    <Internal>
      <!--
        Large receive buffer: camera topics produce bursts of large messages.
        Default OS buffer (212 KB) is far too small; 16 MB prevents EAGAIN drops.
        Note: requires  sysctl -w net.core.rmem_max=67108864  (see robot_tuning.sh)
      -->
      <SocketReceiveBufferSize min="16MB"/>
      <SocketSendBufferSize    min="4MB"/>

      <!--
        Faster heartbeats catch dead subscribers/publishers quickly so camera
        nodes don't keep sending to a lost remote viewer (wasting bandwidth).
        max=200ms is still gentle on CPU; 5ms min covers burst scenarios.
      -->
      <HeartbeatInterval max="200ms" min="5ms" minfixup="25ms"/>

      <!--
        Reduce NACK suppression so retransmit requests come faster after a drop.
        Default is 1 s which is terrible for camera streams.
      -->
      <NackDelay>10ms</NackDelay>

      <!--
        Throttle lease duration: if a participant doesn't send a heartbeat for
        this long it's considered dead. Lower = faster cleanup of stale entries.
      -->
      <LeaseExpiryDelay>5s</LeaseExpiryDelay>
    </Internal>

    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <!--
        Limit discovery to localhost only.  All ROS2 nodes run on the same machine.
        Remote RViz/rqt must connect via DDS bridge or forwarded UDP — not raw
        multicast which gets dropped by most WiFi APs.
      -->
      <Peers>
        <Peer Address="localhost"/>
      </Peers>
    </Discovery>

    <Tracing>
      <!-- Set to "config,warning,error" to debug DDS issues; leave empty in production -->
      <Verbosity>error</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>

  </Domain>
</CycloneDDS>
